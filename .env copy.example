# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Playwright MCP Wrapper Server
# Copy to .env and fill in real values. NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Retry / Timeout ───────────────────────────────────────────────────────────
HARNESS_RETRY_COUNT=3
HARNESS_RETRY_DELAY=1.5
HARNESS_TIMEOUT=30.0

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_SERVICE_NAME=playwright-mcp-wrapper
# Get this from Azure Portal → Application Insights → Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false

# ── Playwright ────────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
# Override if npx is not on PATH
PLAYWRIGHT_MCP_COMMAND=npx
PLAYWRIGHT_MCP_ARGS=@playwright/mcp@latest

# ── Authentication ────────────────────────────────────────────────────────────
LOGIN_URL=https://app.schoology.com/login
SCHOOLOGY_EMAIL=your-email@example.com
SCHOOLOGY_PASSWORD=your-password
SESSION_TTL_SECONDS=3600

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_MODE=stdio        # stdio | http
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
